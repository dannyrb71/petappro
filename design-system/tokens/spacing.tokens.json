{
  "spacing": {
    "primitive": {
      "0":  { "$value": "0px",  "$type": "dimension" },
      "1":  { "$value": "4px",  "$type": "dimension" },
      "2":  { "$value": "8px",  "$type": "dimension" },
      "3":  { "$value": "12px", "$type": "dimension" },
      "4":  { "$value": "16px", "$type": "dimension" },
      "5":  { "$value": "20px", "$type": "dimension" },
      "6":  { "$value": "24px", "$type": "dimension" },
      "8":  { "$value": "32px", "$type": "dimension" },
      "10": { "$value": "40px", "$type": "dimension" },
      "12": { "$value": "48px", "$type": "dimension" },
      "16": { "$value": "64px", "$type": "dimension" }
    },
    "semantic": {
      "tight":        { "$value": "{spacing.primitive.2}", "$type": "dimension" },
      "snug":         { "$value": "{spacing.primitive.3}", "$type": "dimension" },
      "gutter":       { "$value": "{spacing.primitive.5}", "$type": "dimension" },
      "card-padding": { "$value": "{spacing.primitive.5}", "$type": "dimension" },
      "section-gap":  { "$value": "{spacing.primitive.5}", "$type": "dimension" },
      "block-gap":    { "$value": "{spacing.primitive.6}", "$type": "dimension" }
    }
  }
}
