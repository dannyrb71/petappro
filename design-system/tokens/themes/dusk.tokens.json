{
  "$description": "Tier 2 · Themes — dusk mode. Brand roles alias primitives; one file = one Figma mode.",
  "color": {
    "$type": "color",
    "brand": {
      "primary": {
        "$value": "{color.primitive.dusk-brand.700}"
      },
      "primary-pressed": {
        "$value": "{color.primitive.dusk-brand.800}"
      },
      "on-primary": {
        "$value": "{color.primitive.white}"
      },
      "primary-container": {
        "$value": "{color.primitive.dusk-brand.50}"
      },
      "on-primary-container": {
        "$value": "{color.primitive.dusk-brand.900}"
      },
      "secondary": {
        "$value": "{color.primitive.dusk-accent.400}"
      },
      "secondary-solid": {
        "$value": "{color.primitive.dusk-accent.600}"
      },
      "on-secondary": {
        "$value": "{color.primitive.white}"
      },
      "secondary-container": {
        "$value": "{color.primitive.dusk-accent.50}"
      },
      "on-secondary-container": {
        "$value": "{color.primitive.dusk-accent.900}"
      },
      "surface": {
        "$value": "{color.primitive.dusk-neutral.50}"
      },
      "surface-container": {
        "$value": "{color.primitive.dusk-neutral.100}"
      },
      "surface-container-high": {
        "$value": "{color.primitive.dusk-neutral.300}"
      },
      "on-surface": {
        "$value": "{color.primitive.dusk-neutral.900}"
      },
      "on-surface-body": {
        "$value": "{color.primitive.dusk-neutral.800}"
      },
      "on-surface-variant": {
        "$value": "{color.primitive.dusk-neutral.700}"
      },
      "on-surface-accent": {
        "$value": "{color.primitive.dusk-accent.600}"
      },
      "outline": {
        "$value": "{color.primitive.dusk-neutral.400}"
      },
      "outline-variant": {
        "$value": "{color.primitive.dusk-neutral.200}"
      },
      "outline-strong": {
        "$value": "{color.primitive.dusk-neutral.600}"
      },
      "focus-ring": {
        "$value": "rgba(62,76,122,0.28)",
        "$extensions": {
          "ds": {
            "allowLiteral": "translucent focus ring; alpha overlay, no solid primitive equivalent"
          }
        }
      }
    }
  },
  "typography": {
    "$type": "fontFamily",
    "semantic": {
      "font-family": {
        "$value": "{typography.primitive.family.manrope}",
        "$description": "dusk paired typeface (Tier 2)"
      }
    }
  }
}