{
  "$description": "Tier 2 · Themes — Sage & Sand · Dark (Option A, light-islands). Brand-tinted dark canvas (pine.900), light holder cards kept from the light mode, brightened primary. Same role names.",
  "color": {
    "$type": "color",
    "brand": {
      "primary": {
        "$value": "{color.primitive.pine.300}"
      },
      "primary-pressed": {
        "$value": "{color.primitive.pine.400}"
      },
      "on-primary": {
        "$value": "{color.primitive.pine.900}"
      },
      "primary-container": {
        "$value": "{color.primitive.pine.50}"
      },
      "on-primary-container": {
        "$value": "{color.primitive.pine.900}"
      },
      "secondary": {
        "$value": "{color.primitive.sage.300}"
      },
      "secondary-solid": {
        "$value": "{color.primitive.sage.400}"
      },
      "on-secondary": {
        "$value": "{color.primitive.sage.900}"
      },
      "secondary-container": {
        "$value": "{color.primitive.sage.50}"
      },
      "on-secondary-container": {
        "$value": "{color.primitive.sage.900}"
      },
      "surface": {
        "$value": "{color.primitive.sand.100}"
      },
      "surface-container": {
        "$value": "{color.primitive.sand.200}"
      },
      "surface-container-high": {
        "$value": "{color.primitive.sand.200}"
      },
      "on-surface": {
        "$value": "{color.primitive.ink.900}"
      },
      "on-surface-body": {
        "$value": "{color.primitive.ink.700}"
      },
      "on-surface-variant": {
        "$value": "{color.primitive.taupe.600}"
      },
      "on-surface-accent": {
        "$value": "{color.primitive.sage.700}"
      },
      "outline": {
        "$value": "{color.primitive.sand.300}"
      },
      "outline-variant": {
        "$value": "{color.primitive.sand.200}"
      },
      "outline-strong": {
        "$value": "{color.primitive.sand.400}"
      },
      "focus-ring": {
        "$value": "rgba(31,78,68,0.22)",
        "$extensions": {
          "ds": {
            "allowLiteral": "translucent focus ring; alpha overlay, no solid primitive equivalent"
          }
        }
      },
      "canvas": {
        "$value": "{color.primitive.pine.900}"
      },
      "on-canvas": {
        "$value": "{color.primitive.sand.50}"
      },
      "on-canvas-variant": {
        "$value": "{color.primitive.sand.400}"
      },
      "on-canvas-accent": {
        "$value": "{color.primitive.sage.300}"
      },
      "primary-on-surface": {
        "$value": "{color.primitive.pine.800}"
      },
      "primary-on-surface-label": {
        "$value": "{color.primitive.white}"
      },
      "primary-on-surface-pressed": {
        "$value": "{color.primitive.pine.900}"
      },
      "canvas-pressed": {
        "$value": "{color.primitive.pine.800}"
      }
    }
  },
  "typography": {
    "$type": "fontFamily",
    "semantic": {
      "font-family": {
        "$value": "{typography.primitive.family.sans}",
        "$description": "Sage & Sand paired typeface (Hanken Grotesk)"
      }
    }
  }
}
