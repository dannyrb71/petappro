{
  "$description": "Tier 2 \u00b7 Themes \u2014 harbor mode. Brand roles alias primitives; one file = one Figma mode.",
  "color": {
    "$type": "color",
    "brand": {
      "primary": {
        "$value": "{color.primitive.harbor-brand.400}"
      },
      "primary-hover": {
        "$value": "{color.primitive.harbor-brand.200}"
      },
      "primary-pressed": {
        "$value": "{color.primitive.harbor-brand.900}"
      },
      "on-primary": {
        "$value": "{color.primitive.white}"
      },
      "primary-container": {
        "$value": "{color.primitive.harbor-brand.50}"
      },
      "on-primary-container": {
        "$value": "{color.primitive.harbor-brand.700}"
      },
      "secondary": {
        "$value": "{color.primitive.harbor-accent.200}"
      },
      "secondary-solid": {
        "$value": "{color.primitive.harbor-accent.400}"
      },
      "secondary-hover": {
        "$value": "{color.primitive.harbor-accent.700}"
      },
      "on-secondary": {
        "$value": "{color.primitive.white}"
      },
      "secondary-container": {
        "$value": "{color.primitive.harbor-accent.50}"
      },
      "on-secondary-container": {
        "$value": "{color.primitive.harbor-accent.900}"
      },
      "surface": {
        "$value": "{color.primitive.harbor-neutral.50}"
      },
      "surface-container": {
        "$value": "{color.primitive.harbor-neutral.100}"
      },
      "surface-container-high": {
        "$value": "{color.primitive.harbor-neutral.300}"
      },
      "on-surface": {
        "$value": "{color.primitive.harbor-neutral.900}"
      },
      "on-surface-body": {
        "$value": "{color.primitive.harbor-neutral.800}"
      },
      "on-surface-variant": {
        "$value": "{color.primitive.harbor-neutral.700}"
      },
      "on-surface-accent": {
        "$value": "{color.primitive.harbor-accent.400}"
      },
      "outline": {
        "$value": "{color.primitive.harbor-neutral.400}"
      },
      "outline-variant": {
        "$value": "{color.primitive.harbor-neutral.200}"
      },
      "outline-strong": {
        "$value": "{color.primitive.harbor-neutral.600}"
      },
      "focus-ring": {
        "$value": "rgba(14,61,66,0.28)",
        "$extensions": {
          "ds": {
            "allowLiteral": "translucent focus ring; alpha overlay, no solid primitive equivalent"
          }
        }
      }
    }
  },
  "typography": {
    "$type": "fontFamily",
    "semantic": {
      "font-family": {
        "$value": "{typography.primitive.family.lexend}",
        "$description": "harbor paired typeface (Tier 2)"
      }
    }
  }
}
