{
  "$description": "Tier 2 · Themes — berry mode. Brand roles alias primitives; one file = one Figma mode.",
  "color": {
    "$type": "color",
    "brand": {
      "primary": {
        "$value": "{color.primitive.berry-brand.700}"
      },
      "primary-pressed": {
        "$value": "{color.primitive.berry-brand.800}"
      },
      "on-primary": {
        "$value": "{color.primitive.white}"
      },
      "primary-container": {
        "$value": "{color.primitive.berry-brand.50}"
      },
      "on-primary-container": {
        "$value": "{color.primitive.berry-brand.900}"
      },
      "secondary": {
        "$value": "{color.primitive.berry-accent.500}"
      },
      "secondary-solid": {
        "$value": "{color.primitive.berry-accent.600}"
      },
      "on-secondary": {
        "$value": "{color.primitive.white}"
      },
      "secondary-container": {
        "$value": "{color.primitive.berry-accent.50}"
      },
      "on-secondary-container": {
        "$value": "{color.primitive.berry-accent.900}"
      },
      "surface": {
        "$value": "{color.primitive.berry-neutral.50}"
      },
      "surface-container": {
        "$value": "{color.primitive.berry-neutral.100}"
      },
      "surface-container-high": {
        "$value": "{color.primitive.berry-neutral.300}"
      },
      "on-surface": {
        "$value": "{color.primitive.berry-neutral.900}"
      },
      "on-surface-body": {
        "$value": "{color.primitive.berry-neutral.800}"
      },
      "on-surface-variant": {
        "$value": "{color.primitive.berry-neutral.700}"
      },
      "on-surface-accent": {
        "$value": "{color.primitive.berry-accent.700}"
      },
      "outline": {
        "$value": "{color.primitive.berry-neutral.400}"
      },
      "outline-variant": {
        "$value": "{color.primitive.berry-neutral.200}"
      },
      "outline-strong": {
        "$value": "{color.primitive.berry-neutral.600}"
      },
      "focus-ring": {
        "$value": "rgba(107,74,122,0.28)",
        "$extensions": {
          "ds": {
            "allowLiteral": "translucent focus ring; alpha overlay, no solid primitive equivalent"
          }
        }
      }
    }
  },
  "typography": {
    "$type": "fontFamily",
    "semantic": {
      "font-family": {
        "$value": "{typography.primitive.family.source-serif}",
        "$description": "berry paired typeface (Tier 2)"
      }
    }
  }
}