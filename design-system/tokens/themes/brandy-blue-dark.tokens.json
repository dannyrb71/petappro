{
  "$description": "Tier 2 · Themes — Brandy Blue · Dark (PetAppro base brand — DEFAULT dark preset, Option A). Model 1 'light islands': brand-tinted dark-teal canvas, WHITE holder cards (same as light), inner one step darker. Brightened primary pops on the dark canvas. Poppins.",
  "color": {
    "$type": "color",
    "brand": {
      "primary": {
        "$value": "{color.primitive.brandy-blue.500}"
      },
      "primary-pressed": {
        "$value": "{color.primitive.brandy-blue.600}"
      },
      "on-primary": {
        "$value": "{color.primitive.brandy-blue.900}"
      },
      "primary-container": {
        "$value": "{color.primitive.brandy-blue.100}"
      },
      "on-primary-container": {
        "$value": "{color.primitive.brandy-blue.900}"
      },
      "secondary": {
        "$value": "{color.primitive.camo.600}"
      },
      "secondary-solid": {
        "$value": "{color.primitive.camo.700}"
      },
      "on-secondary": {
        "$value": "{color.primitive.white}"
      },
      "secondary-container": {
        "$value": "{color.primitive.camo.100}"
      },
      "on-secondary-container": {
        "$value": "{color.primitive.camo.900}"
      },
      "canvas": {
        "$value": "{color.primitive.brandy-blue.900}"
      },
      "on-canvas": {
        "$value": "{color.primitive.maverick.50}"
      },
      "on-canvas-variant": {
        "$value": "{color.primitive.maverick.400}"
      },
      "surface": {
        "$value": "{color.primitive.white}"
      },
      "surface-container": {
        "$value": "{color.primitive.maverick.100}"
      },
      "surface-container-high": {
        "$value": "{color.primitive.maverick.200}"
      },
      "on-surface": {
        "$value": "{color.primitive.maverick.900}"
      },
      "on-surface-body": {
        "$value": "{color.primitive.maverick.700}"
      },
      "on-surface-variant": {
        "$value": "{color.primitive.maverick.600}"
      },
      "on-surface-accent": {
        "$value": "{color.primitive.brandy-blue.600}"
      },
      "outline": {
        "$value": "{color.primitive.maverick.200}"
      },
      "outline-variant": {
        "$value": "{color.primitive.maverick.100}"
      },
      "outline-strong": {
        "$value": "{color.primitive.maverick.300}"
      },
      "focus-ring": {
        "$value": "rgba(111,199,207,0.32)",
        "$extensions": {
          "ds": {
            "allowLiteral": "translucent focus ring; alpha overlay, no solid primitive equivalent"
          }
        }
      }
    }
  },
  "typography": {
    "$type": "fontFamily",
    "semantic": {
      "font-family": {
        "$value": "{typography.primitive.family.poppins}",
        "$description": "Brandy Blue paired typeface (Poppins)"
      }
    }
  }
}
