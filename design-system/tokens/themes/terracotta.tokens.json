{
  "$description": "Tier 2 \u00b7 Themes \u2014 terracotta mode. Brand roles alias primitives; one file = one Figma mode.",
  "color": {
    "$type": "color",
    "brand": {
      "primary": {
        "$value": "{color.primitive.terracotta-brand.200}"
      },
      "primary-hover": {
        "$value": "{color.primitive.terracotta-brand.400}"
      },
      "primary-pressed": {
        "$value": "{color.primitive.terracotta-brand.700}"
      },
      "on-primary": {
        "$value": "{color.primitive.white}"
      },
      "primary-container": {
        "$value": "{color.primitive.terracotta-brand.50}"
      },
      "on-primary-container": {
        "$value": "{color.primitive.terracotta-brand.900}"
      },
      "secondary": {
        "$value": "{color.primitive.terracotta-accent.200}"
      },
      "secondary-solid": {
        "$value": "{color.primitive.terracotta-accent.400}"
      },
      "secondary-hover": {
        "$value": "{color.primitive.terracotta-accent.700}"
      },
      "on-secondary": {
        "$value": "{color.primitive.white}"
      },
      "secondary-container": {
        "$value": "{color.primitive.terracotta-accent.50}"
      },
      "on-secondary-container": {
        "$value": "{color.primitive.terracotta-accent.900}"
      },
      "surface": {
        "$value": "{color.primitive.terracotta-neutral.50}"
      },
      "surface-container": {
        "$value": "{color.primitive.terracotta-neutral.100}"
      },
      "surface-container-high": {
        "$value": "{color.primitive.terracotta-neutral.300}"
      },
      "on-surface": {
        "$value": "{color.primitive.terracotta-neutral.900}"
      },
      "on-surface-body": {
        "$value": "{color.primitive.terracotta-neutral.800}"
      },
      "on-surface-variant": {
        "$value": "{color.primitive.terracotta-neutral.700}"
      },
      "on-surface-accent": {
        "$value": "{color.primitive.terracotta-accent.400}"
      },
      "outline": {
        "$value": "{color.primitive.terracotta-neutral.400}"
      },
      "outline-variant": {
        "$value": "{color.primitive.terracotta-neutral.200}"
      },
      "outline-strong": {
        "$value": "{color.primitive.terracotta-neutral.600}"
      },
      "focus-ring": {
        "$value": "rgba(192,139,110,0.30)",
        "$extensions": {
          "ds": {
            "allowLiteral": "translucent focus ring; alpha overlay, no solid primitive equivalent"
          }
        }
      }
    }
  },
  "typography": {
    "$type": "fontFamily",
    "semantic": {
      "font-family": {
        "$value": "{typography.primitive.family.nunito-sans}",
        "$description": "terracotta paired typeface (Tier 2)"
      }
    }
  }
}
