{
  "color": {
    "$type": "color",
    "primitive": {
      "base": {
        "white": {
          "$value": "#FFFFFF",
          "$description": "Pure white."
        },
        "black": {
          "$value": "#000000",
          "$description": "Pure black."
        },
        "transparent": {
          "$value": "#FFFFFF00",
          "$description": "Fully transparent white."
        }
      },
      "trust-teal": {
        "$description": "Primary Petappro brand scale.",
        "100": { "$value": "#E6F5F7" },
        "200": { "$value": "#CDECEF" },
        "300": { "$value": "#9EDADF" },
        "400": { "$value": "#6FC7CF" },
        "500": { "$value": "#32A8B5" },
        "600": { "$value": "#006073" },
        "700": { "$value": "#004F60" },
        "800": { "$value": "#003E4D" },
        "900": { "$value": "#002C38" }
      },
      "verify-green": {
        "$description": "Secondary brand and positive-state scale.",
        "100": { "$value": "#F0F8E8" },
        "200": { "$value": "#DDEFCB" },
        "300": { "$value": "#C2E39E" },
        "400": { "$value": "#A3D56D" },
        "500": { "$value": "#84C341" },
        "600": { "$value": "#68A82F" },
        "700": { "$value": "#508522" },
        "800": { "$value": "#386318" },
        "900": { "$value": "#23420E" }
      },
      "warm-coral": {
        "$description": "Tertiary brand, attention and danger-state scale.",
        "100": { "$value": "#FFF0EC" },
        "200": { "$value": "#FFDAD1" },
        "300": { "$value": "#FFB9A8" },
        "400": { "$value": "#FF9179" },
        "500": { "$value": "#F36B4F" },
        "600": { "$value": "#D95137" },
        "700": { "$value": "#B33C27" },
        "800": { "$value": "#872919" },
        "900": { "$value": "#5D190E" }
      },
      "clear-sky": {
        "$description": "Informational and interactive accent scale.",
        "100": { "$value": "#EAF6FF" },
        "200": { "$value": "#D1EAFC" },
        "300": { "$value": "#A7D8F6" },
        "400": { "$value": "#72C0EC" },
        "500": { "$value": "#3AA5DD" },
        "600": { "$value": "#1687C0" },
        "700": { "$value": "#0F6B9A" },
        "800": { "$value": "#0A4F73" },
        "900": { "$value": "#06344D" }
      },
      "professional-slate": {
        "$description": "Neutral interface and typography scale.",
        "100": { "$value": "#F4F7F8" },
        "200": { "$value": "#E5EBED" },
        "300": { "$value": "#C8D3D7" },
        "400": { "$value": "#A5B5BB" },
        "500": { "$value": "#7B9098" },
        "600": { "$value": "#5F737B" },
        "700": { "$value": "#465A62" },
        "800": { "$value": "#304249" },
        "900": { "$value": "#1C2C32" }
      }
    },
    "semantic": {
      "brand": {
        "primary": {
          "default": {
            "$value": "{color.primitive.trust-teal.600}",
            "$description": "Primary brand color and default primary action."
          },
          "hover": { "$value": "{color.primitive.trust-teal.700}" },
          "pressed": { "$value": "{color.primitive.trust-teal.800}" },
          "subtle": { "$value": "{color.primitive.trust-teal.100}" }
        },
        "secondary": {
          "default": {
            "$value": "{color.primitive.verify-green.500}",
            "$description": "Verification, completion and secondary brand color."
          },
          "hover": { "$value": "{color.primitive.verify-green.600}" },
          "pressed": { "$value": "{color.primitive.verify-green.700}" },
          "subtle": { "$value": "{color.primitive.verify-green.100}" }
        },
        "tertiary": {
          "default": {
            "$value": "{color.primitive.warm-coral.500}",
            "$description": "Warm tertiary brand accent."
          },
          "hover": { "$value": "{color.primitive.warm-coral.600}" },
          "pressed": { "$value": "{color.primitive.warm-coral.700}" },
          "subtle": { "$value": "{color.primitive.warm-coral.100}" }
        },
        "accent": {
          "default": {
            "$value": "{color.primitive.clear-sky.600}",
            "$description": "Informational and interactive accent."
          },
          "hover": { "$value": "{color.primitive.clear-sky.700}" },
          "pressed": { "$value": "{color.primitive.clear-sky.800}" },
          "subtle": { "$value": "{color.primitive.clear-sky.100}" }
        }
      },
      "text": {
        "primary": { "$value": "{color.primitive.professional-slate.900}" },
        "secondary": { "$value": "{color.primitive.professional-slate.700}" },
        "tertiary": { "$value": "{color.primitive.professional-slate.600}" },
        "disabled": { "$value": "{color.primitive.professional-slate.400}" },
        "inverse": { "$value": "{color.primitive.base.white}" },
        "brand": { "$value": "{color.primitive.trust-teal.700}" },
        "link": { "$value": "{color.primitive.clear-sky.700}" },
        "link-hover": { "$value": "{color.primitive.clear-sky.800}" },
        "success": { "$value": "{color.primitive.verify-green.800}" },
        "danger": { "$value": "{color.primitive.warm-coral.700}" }
      },
      "icon": {
        "primary": { "$value": "{color.primitive.professional-slate.900}" },
        "secondary": { "$value": "{color.primitive.professional-slate.600}" },
        "disabled": { "$value": "{color.primitive.professional-slate.400}" },
        "inverse": { "$value": "{color.primitive.base.white}" },
        "brand": { "$value": "{color.primitive.trust-teal.600}" },
        "success": { "$value": "{color.primitive.verify-green.600}" },
        "danger": { "$value": "{color.primitive.warm-coral.600}" },
        "info": { "$value": "{color.primitive.clear-sky.600}" }
      },
      "background": {
        "canvas": { "$value": "{color.primitive.base.white}" },
        "surface": { "$value": "{color.primitive.base.white}" },
        "subtle": { "$value": "{color.primitive.professional-slate.100}" },
        "muted": { "$value": "{color.primitive.professional-slate.200}" },
        "inverse": { "$value": "{color.primitive.professional-slate.900}" },
        "brand": { "$value": "{color.primitive.trust-teal.600}" },
        "brand-subtle": { "$value": "{color.primitive.trust-teal.100}" },
        "success-subtle": { "$value": "{color.primitive.verify-green.100}" },
        "danger-subtle": { "$value": "{color.primitive.warm-coral.100}" },
        "info-subtle": { "$value": "{color.primitive.clear-sky.100}" }
      },
      "border": {
        "subtle": { "$value": "{color.primitive.professional-slate.200}" },
        "default": { "$value": "{color.primitive.professional-slate.300}" },
        "strong": { "$value": "{color.primitive.professional-slate.500}" },
        "inverse": { "$value": "{color.primitive.professional-slate.700}" },
        "brand": { "$value": "{color.primitive.trust-teal.500}" },
        "success": { "$value": "{color.primitive.verify-green.500}" },
        "danger": { "$value": "{color.primitive.warm-coral.500}" },
        "focus": { "$value": "{color.primitive.clear-sky.600}" }
      },
      "action": {
        "primary": {
          "background": { "$value": "{color.primitive.trust-teal.600}" },
          "background-hover": { "$value": "{color.primitive.trust-teal.700}" },
          "background-pressed": { "$value": "{color.primitive.trust-teal.800}" },
          "background-disabled": { "$value": "{color.primitive.professional-slate.300}" },
          "foreground": { "$value": "{color.primitive.base.white}" },
          "foreground-disabled": { "$value": "{color.primitive.professional-slate.600}" }
        },
        "secondary": {
          "background": { "$value": "{color.primitive.base.white}" },
          "background-hover": { "$value": "{color.primitive.trust-teal.100}" },
          "background-pressed": { "$value": "{color.primitive.trust-teal.200}" },
          "background-disabled": { "$value": "{color.primitive.professional-slate.100}" },
          "foreground": { "$value": "{color.primitive.trust-teal.700}" },
          "foreground-disabled": { "$value": "{color.primitive.professional-slate.400}" },
          "border": { "$value": "{color.primitive.trust-teal.600}" }
        },
        "destructive": {
          "background": { "$value": "{color.primitive.warm-coral.600}" },
          "background-hover": { "$value": "{color.primitive.warm-coral.700}" },
          "background-pressed": { "$value": "{color.primitive.warm-coral.800}" },
          "foreground": { "$value": "{color.primitive.base.white}" }
        }
      },
      "status": {
        "success": {
          "foreground": { "$value": "{color.primitive.verify-green.800}" },
          "background": { "$value": "{color.primitive.verify-green.100}" },
          "border": { "$value": "{color.primitive.verify-green.400}" }
        },
        "danger": {
          "foreground": { "$value": "{color.primitive.warm-coral.800}" },
          "background": { "$value": "{color.primitive.warm-coral.100}" },
          "border": { "$value": "{color.primitive.warm-coral.400}" }
        },
        "info": {
          "foreground": { "$value": "{color.primitive.clear-sky.800}" },
          "background": { "$value": "{color.primitive.clear-sky.100}" },
          "border": { "$value": "{color.primitive.clear-sky.400}" }
        }
      },
      "overlay": {
        "scrim": {
          "$value": "#1C2C3299",
          "$description": "60% slate overlay for modal scrims."
        }
      }
    }
  }
}
